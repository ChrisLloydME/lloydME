---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { withBase } from "../utils/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  bodyClass?: string;
  mainClass?: string;
  contentClass?: string;
  themeColor?: string;
  fullBleed?: boolean;
}

const {
  title,
  description = SITE_DESCRIPTION,
  lang = "en",
  bodyClass,
  mainClass,
  contentClass,
  themeColor = "#f5f5f7",
  fullBleed = false,
} = Astro.props as Props;
const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const pageDescription = description && description.trim().length > 0 ? description : SITE_DESCRIPTION;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content={pageDescription} name="description" />
    <meta content={SITE_TITLE} name="apple-mobile-web-app-title" />
    <meta content={themeColor} name="theme-color" />
    <link href={withBase("/favicon.svg")} rel="icon" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body class:list={[bodyClass]}>
    <div class="relative min-h-screen">
      <Navbar />
      <main class:list={[fullBleed ? "pb-16 sm:pb-20" : "px-4 pb-16 sm:px-6 sm:pb-20", mainClass]}>
        <div class:list={[!fullBleed && "mx-auto max-w-[1120px]", contentClass]}>
          <slot />
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
