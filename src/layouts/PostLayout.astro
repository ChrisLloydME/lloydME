---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { formatDate, tagToSlug } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props as Props;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-3xl">
    <header class="reveal card-surface mb-10 rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
      <p class="text-sm uppercase tracking-[0.3em] text-[var(--accent)]">Blog Post</p>
      <h1 class="mt-5 font-serif text-4xl leading-tight text-[var(--ink)] sm:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-5 text-lg leading-8 text-[var(--muted)]">{post.data.description}</p>

      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>

        {
          post.data.updatedDate && (
            <span class="flex items-center gap-3">
              <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
              <span>最近更新于 {formatDate(post.data.updatedDate)}</span>
            </span>
          )
        }
      </div>

      {
        post.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <a
                class="rounded-md border border-[var(--line)] bg-white/70 px-3 py-1 text-sm text-[var(--muted)] transition hover:border-[var(--accent)] hover:text-[var(--accent)]"
                href={`/tags/${tagToSlug(tag)}/`}
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="card-surface rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
      <div class="article-flow">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
