---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { withBase } from "../utils/paths";
import { formatDate, getPostSlug, tagToSlug } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props as Props;
const postSlug = getPostSlug(post);
const isBlueImmersive = post.data.pageTheme === "blue-immersive";
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  lang="zh-CN"
  bodyClass={isBlueImmersive ? "theme-blue-immersive" : undefined}
  mainClass={isBlueImmersive ? "pb-24 sm:pb-28" : undefined}
  contentClass={isBlueImmersive ? "max-w-none" : undefined}
  themeColor={isBlueImmersive ? "#4c719d" : undefined}
  fullBleed={isBlueImmersive}
>
  <article
    class:list={
      isBlueImmersive
        ? "article-page article-page-blue mx-auto max-w-none px-0 pb-0"
        : "article-page-internet mx-auto max-w-4xl px-4 pb-6 sm:px-6"
    }
    data-post-slug={postSlug}
  >
    <header
      class:list={
        isBlueImmersive
          ? "reveal article-hero article-hero-blue px-0 pt-0 pb-10 text-center sm:pb-12"
          : "reveal article-hero px-6 py-12 text-center sm:px-10 sm:py-16"
      }
    >
      {
        post.data.heroImage && (
          <div class:list={["article-cover-wrap", isBlueImmersive && "article-cover-wrap-blue"]}>
            <img
              src={post.data.heroImage.src}
              alt={post.data.heroImageAlt ?? post.data.title}
              class:list={["article-cover", isBlueImmersive && "article-cover-blue"]}
            />

            {
              isBlueImmersive && (
                <div class="article-hero-copy article-hero-copy-blue">
                  <p class="section-kicker">Essay</p>
                  <h1 class="article-title mt-4">{post.data.title}</h1>

                  {post.data.description && <p class="section-copy mx-auto mt-5">{post.data.description}</p>}

                  <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-[var(--muted)]">
                    <span class="article-meta-chip">
                      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    </span>

                    {
                      post.data.updatedDate && (
                        <span class="article-meta-chip">Updated on {formatDate(post.data.updatedDate)}</span>
                      )
                    }
                  </div>

                  {
                    post.data.tags.length > 0 && (
                      <div class="mt-6 flex flex-wrap justify-center gap-2">
                        {post.data.tags.map((tag) => (
                          <a class="article-tag" href={withBase(`/tags/${tagToSlug(tag)}/`)}>
                            #{tag}
                          </a>
                        ))}
                      </div>
                    )
                  }
                </div>
              )
            }

            {
              isBlueImmersive && <></>
            }
          </div>
        )
      }

      {
        !isBlueImmersive && (
          <div class="article-hero-copy">
            <p class="section-kicker">Essay</p>
            <h1 class="article-title mt-4">{post.data.title}</h1>

            {post.data.description && <p class="section-copy mx-auto mt-5">{post.data.description}</p>}

            <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm text-[var(--muted)]">
              <span class="article-meta-chip">
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              </span>

              {
                post.data.updatedDate && (
                  <span class="article-meta-chip">Updated on {formatDate(post.data.updatedDate)}</span>
                )
              }
            </div>

            {
              post.data.tags.length > 0 && (
                <div class="mt-6 flex flex-wrap justify-center gap-2">
                  {post.data.tags.map((tag) => (
                  <a class="article-tag" href={withBase(`/tags/${tagToSlug(tag)}/`)}>
                    #{tag}
                  </a>
                  ))}
                </div>
              )
            }
          </div>
        )
      }
    </header>

    <div class:list={["article-shell", isBlueImmersive && "article-shell-blue"]}>
      <div class="article-flow">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
