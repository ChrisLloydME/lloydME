---
import { getCollection } from "astro:content";
import frontPageFlyEmirates from "../assets/home/front-page-fly-emirates.jpg";
import { projects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
import { getPostSlug, sortBlogPosts } from "../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
const featuredPost = posts.find((post) => getPostSlug(post) === "fly-emirates-fly-better") ?? posts[0];
const featuredPostHref = featuredPost ? withBase(`/blog/${getPostSlug(featuredPost)}/`) : withBase("/blog/");
const audioMator = projects.find((project) => project.slug === "audiomator");
---

<BaseLayout fullBleed mainClass="pb-0">
  <section class="home-feature-stack">
    <div class="home-feature">
      <a class="home-feature-card" data-home-feature-primary href={featuredPostHref}>
        <div class="home-feature-image-wrap">
          <img
            src={frontPageFlyEmirates.src}
            alt="A plane trail rising across a blue sky."
            class="home-feature-image"
          />
        </div>

        <div class="home-feature-copy">
          <span class="home-feature-kicker">Blog</span>
          <h1 class="home-feature-title">
            <span class="home-feature-title-line">Fly&nbsp;Emirates,</span>
            <span class="home-feature-title-line">Fly Better</span>
          </h1>
        </div>
      </a>
    </div>

    {
      audioMator && (
        <div class="home-feature">
          <a
            class="home-project-card"
            data-home-feature-secondary
            href={withBase(`/projects/${audioMator.slug}/`)}
          >
            <div class="home-project-visual">
              <div class="home-project-glow"></div>
              <img
                src={withBase(audioMator.icon)}
                alt={`${audioMator.name} app icon`}
                class="home-project-icon"
              />
            </div>

            <div class="home-project-copy">
              <span class="home-feature-kicker">Project</span>
              <h2 class="home-project-title">{audioMator.name}</h2>
              <p class="home-project-summary">{audioMator.headline}</p>
            </div>
          </a>
        </div>
      )
    }
  </section>

  <script is:inline>
    (() => {
      const primaryCard = document.querySelector("[data-home-feature-primary]");
      const secondaryCard = document.querySelector("[data-home-feature-secondary]");

      if (!(primaryCard instanceof HTMLElement) || !(secondaryCard instanceof HTMLElement)) {
        return;
      }

      let frame = 0;

      const syncProjectCardHeight = () => {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          const primaryHeight = Math.ceil(primaryCard.getBoundingClientRect().height);
          secondaryCard.style.height = `${primaryHeight}px`;
          secondaryCard.style.minHeight = `${primaryHeight}px`;
        });
      };

      syncProjectCardHeight();

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(syncProjectCardHeight);
        observer.observe(primaryCard);
      } else {
        window.addEventListener("resize", syncProjectCardHeight);
      }

      window.addEventListener("load", syncProjectCardHeight, { once: true });
      window.addEventListener("resize", syncProjectCardHeight);
    })();
  </script>
</BaseLayout>
