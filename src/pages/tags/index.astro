---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
const tags = getAllTags(posts);
---

<BaseLayout title="Tags">
  <section class="reveal mx-auto max-w-5xl space-y-6">
    <div class="px-7 py-14 text-center sm:px-10 sm:py-16">
      <p class="section-kicker">Tags</p>
      <h1 class="section-heading-sm mt-3">Tag archive</h1>
      <p class="section-copy mx-auto mt-6">
        Tags let visitors browse a shared topic across posts and can later expand into archives, thematic hubs, or a broader content index.
      </p>
    </div>

    <div class="grid gap-4">
      {tags.map((tag) => (
        <a
          class="section-rail block p-0 pt-8"
          href={`/tags/${tag.slug}/`}
        >
          <p class="font-[family:var(--font-title)] text-3xl font-semibold tracking-[-0.015em] text-[var(--ink)]">#{tag.label}</p>
          <p class="mt-3 text-sm text-[var(--muted)]">{tag.count} posts</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
