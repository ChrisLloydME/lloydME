---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
const tags = getAllTags(posts);
---

<BaseLayout title="标签">
  <section class="reveal space-y-6">
    <div class="card-surface rounded-2xl px-7 py-10 sm:px-10 sm:py-12">
      <p class="text-sm uppercase tracking-[0.3em] text-[var(--accent)]">Tags</p>
      <h1 class="mt-4 font-serif text-5xl text-[var(--ink)]">标签归档</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)]">
        标签页帮助访客跨文章浏览同一主题，也方便后续扩展成归档页、专题页或内容索引。
      </p>
    </div>

    <div class="grid gap-4">
      {tags.map((tag) => (
        <a
          class="card-surface rounded-2xl p-6 transition hover:-translate-y-1 hover:border-[rgba(196,111,71,0.35)]"
          href={`/tags/${tag.slug}/`}
        >
          <p class="font-serif text-2xl text-[var(--ink)]">#{tag.label}</p>
          <p class="mt-3 text-sm text-[var(--muted)]">{tag.count} 篇文章</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
