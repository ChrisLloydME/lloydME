---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
const tags = getAllTags(posts);
---

<BaseLayout title="标签">
  <section class="reveal mx-auto max-w-5xl space-y-6">
    <div class="px-7 py-14 text-center sm:px-10 sm:py-16">
      <p class="section-kicker">Tags</p>
      <h1 class="section-heading-sm mt-3">标签归档</h1>
      <p class="section-copy mx-auto mt-6">
        标签页帮助访客跨文章浏览同一主题，也方便后续扩展成归档页、专题页或内容索引。
      </p>
    </div>

    <div class="grid gap-4">
      {tags.map((tag) => (
        <a
          class="section-rail block p-0 pt-8"
          href={`/tags/${tag.slug}/`}
        >
          <p class="text-3xl font-semibold tracking-[-0.04em] text-[var(--ink)]">#{tag.label}</p>
          <p class="mt-3 text-sm text-[var(--muted)]">{tag.count} 篇文章</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
