---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPostsByTag, sortBlogPosts, type TagSummary } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = sortBlogPosts(
    (await getCollection("blog")).filter((post) => !post.data.draft),
  );

  return getAllTags(posts).map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tag,
      posts: getPostsByTag(posts, tag.slug),
    },
  }));
}

interface Props {
  tag: TagSummary;
  posts: CollectionEntry<"blog">[];
}

const { tag, posts } = Astro.props as Props;
---

<BaseLayout title={`Tag: ${tag.label}`} description={`Browse all posts tagged ${tag.label}.`}>
  <section class="reveal mx-auto max-w-5xl space-y-6">
    <div class="px-4 py-12 text-center sm:px-10 sm:py-16">
      <p class="section-kicker">Tag Archive</p>
      <h1 class="section-heading-sm mt-3">#{tag.label}</h1>
      <p class="section-copy mx-auto mt-6">
        Here you&apos;ll find {posts.length} post{posts.length === 1 ? "" : "s"} related to {tag.label}, all gathered in one place.
      </p>
    </div>

    <div class="grid gap-5">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
