---
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Projects">
  <section class="reveal mx-auto max-w-5xl space-y-6">
    <div class="px-7 py-14 text-center sm:px-10 sm:py-16">
      <p class="section-kicker">Projects</p>
      <h1 class="section-heading-sm mt-3">Projects and experiments</h1>
      <p class="section-copy mx-auto mt-6">
        This is a collection of things I’ve built, explored, or experimented with, along with a bit of context about what they are and why they matter to me.
      </p>
    </div>

    <div class="section-rail grid gap-5 pt-8">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
