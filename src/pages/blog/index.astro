---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
---

<BaseLayout title="Blog">
  <section class="reveal mx-auto max-w-5xl space-y-6">
    <div class="px-4 py-12 text-center sm:px-10 sm:py-16">
      <p class="section-kicker">Blog</p>
      <h1 class="section-heading-sm mt-3">All posts</h1>
      <p class="section-copy mx-auto mt-6">
        Here you’ll find all my posts in one place, with the newest ones first. It’s a simple archive for browsing ideas, notes, and longer pieces over time.
      </p>
      <p class="mt-6 text-sm text-[var(--muted)]">{posts.length} public posts.</p>
    </div>

    <div class="grid gap-5">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
