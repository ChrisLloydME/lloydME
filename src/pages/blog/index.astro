---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(
  (await getCollection("blog")).filter((post) => !post.data.draft),
);
---

<BaseLayout title="博客">
  <section class="reveal space-y-6">
    <div class="card-surface rounded-2xl px-7 py-10 sm:px-10 sm:py-12">
      <p class="text-sm uppercase tracking-[0.3em] text-[var(--accent)]">Blog</p>
      <h1 class="mt-4 font-serif text-5xl text-[var(--ink)]">全部文章</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)]">
        文章按发布时间倒序排列。这个页面适合作为完整索引，也可以继续扩展为系列、年份归档或搜索入口。
      </p>
      <p class="mt-6 text-sm text-[var(--muted)]">当前共有 {posts.length} 篇公开文章。</p>
    </div>

    <div class="grid gap-5">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
