---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects, type Project } from "../../data/projects";
import { withBase } from "../../utils/paths";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
const projectMeta = [project.category, ...project.tags].join(" · ");
---

<BaseLayout title={project.name} description={project.summary}>
  <article class="pb-10 sm:pb-16">
    <section class="project-showcase-hero relative left-1/2 w-screen -translate-x-1/2 overflow-hidden">
      <div class="mx-auto max-w-[1440px] px-6 py-[4.75rem] sm:px-10 sm:py-24 lg:py-28">
        <div class="mx-auto max-w-6xl text-center">
          <img
            src={withBase(project.icon)}
            alt={`${project.name} app icon`}
            class="app-icon-hero-shadow mx-auto h-36 w-36 rounded-[32px] sm:h-40 sm:w-40 sm:rounded-[36px] lg:h-44 lg:w-44 lg:rounded-[40px]"
          />

          <p class="mt-8 font-[family:var(--font-title)] text-[clamp(2rem,3.6vw,4.3rem)] font-semibold leading-none tracking-[-0.02em] text-white/90">
            {project.name}
          </p>
          <h1 class="mx-auto mt-8 max-w-6xl font-[family:var(--font-title)] text-[clamp(4rem,11vw,8.5rem)] font-semibold leading-[0.92] tracking-[-0.025em] text-white">
            {project.heroHeadline}
          </h1>
          <p class="mx-auto mt-8 max-w-6xl font-[family:var(--font-title)] text-[clamp(1.25rem,2.3vw,2.35rem)] font-semibold leading-[1.28] tracking-[-0.01em] text-white/70">
            {project.summary}
          </p>
          <p class="mt-10 text-sm font-medium tracking-[-0.01em] text-white/45 sm:text-base">
            {projectMeta}
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-7 pt-[4.75rem] sm:px-10 sm:pt-24">
      <div class="mx-auto max-w-5xl text-center">
        <p class="section-kicker">Overview</p>
        <h2 class="section-heading-sm mt-3">A cleaner way to fix metadata by hand</h2>
        <p class="mt-6 text-[clamp(1.15rem,1.15vw+0.95rem,1.6rem)] leading-[1.8] tracking-[-0.02em] text-[var(--muted)]">
          {project.intro}
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-7 py-[4.75rem] sm:px-10 sm:py-24">
      <div class="grid gap-5 md:grid-cols-3">
        {project.capabilities.map((capability, index) => (
          <section class="rounded-[2rem] border border-[var(--line)] bg-white p-8 shadow-[0_20px_80px_rgba(29,29,31,0.05)]">
            <p class="text-sm font-semibold tracking-[0.04em] text-[var(--accent)]">
              0{index + 1}
            </p>
            <h3 class="mt-5 font-[family:var(--font-title)] text-3xl font-semibold leading-tight tracking-[-0.015em] text-[var(--ink)]">
              {capability.title}
            </h3>
            <p class="mt-4 leading-8 text-[var(--muted)]">{capability.summary}</p>
          </section>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-7 pb-20 sm:px-10 sm:pb-28">
      <div class="rounded-[2.5rem] bg-[var(--ink)] px-8 py-14 text-center text-white shadow-[0_30px_120px_rgba(29,29,31,0.16)] sm:px-12 sm:py-20">
        <p class="text-sm font-semibold tracking-[0.04em] text-white/55">PRIVACY / VALUE</p>
        <h2 class="mt-4 font-[family:var(--font-title)] text-[clamp(2.5rem,5vw,4.8rem)] font-semibold leading-[1.02] tracking-[-0.02em]">
          Local by design.
        </h2>
        <p class="mx-auto mt-6 max-w-4xl text-[clamp(1.15rem,1.4vw,1.75rem)] leading-[1.6] tracking-[-0.025em] text-white/72">
          {project.privacy}
        </p>
      </div>
    </section>
  </article>
</BaseLayout>
