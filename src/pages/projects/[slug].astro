---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects, type Project } from "../../data/projects";
import { withBase } from "../../utils/paths";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
const projectMeta = [project.category, ...project.tags].join(" · ");
---

<BaseLayout title={project.name} description={project.summary}>
  <article class="pb-10 sm:pb-16">
    <section class="project-showcase-hero relative left-1/2 w-screen -translate-x-1/2 overflow-hidden">
      <div class="mx-auto max-w-[1440px] px-4 py-16 sm:px-10 sm:py-24 lg:py-28">
        <div class="mx-auto max-w-6xl text-center">
          <img
            src={withBase(project.icon)}
            alt={`${project.name} app icon`}
            class="app-icon-hero-shadow mx-auto h-28 w-28 rounded-[26px] sm:h-40 sm:w-40 sm:rounded-[36px] lg:h-44 lg:w-44 lg:rounded-[40px]"
          />

          <p class="mt-6 font-[family:var(--font-title)] text-[clamp(1.5rem,8vw,4.3rem)] font-semibold leading-none tracking-[-0.02em] text-white/90 sm:mt-8">
            {project.name}
          </p>
          <h1 class="mx-auto mt-6 max-w-6xl font-[family:var(--font-title)] text-[clamp(2.8rem,15vw,8.5rem)] font-semibold leading-[0.92] tracking-[-0.025em] text-white sm:mt-8">
            {project.heroHeadline}
          </h1>
          <p class="mx-auto mt-6 max-w-6xl font-[family:var(--font-title)] text-[clamp(1.05rem,5vw,2.35rem)] font-semibold leading-[1.35] tracking-[-0.01em] text-white/70 sm:mt-8 sm:leading-[1.28]">
            {project.summary}
          </p>
          <p class="mt-8 text-sm font-medium tracking-[-0.01em] text-white/45 sm:mt-10 sm:text-base">
            {projectMeta}
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pt-16 sm:px-10 sm:pt-24">
      <div class="mx-auto max-w-5xl text-center">
        <p class="section-kicker">Overview</p>
        <h2 class="section-heading-sm mt-3">A cleaner way to fix metadata by hand</h2>
        <p class="mt-6 text-[clamp(1.02rem,1.15vw+0.95rem,1.6rem)] leading-[1.75] tracking-[-0.02em] text-[var(--muted)] sm:leading-[1.8]">
          {project.intro}
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-10 sm:py-24">
      <div class="grid gap-5 md:grid-cols-3">
        {project.capabilities.map((capability, index) => (
          <section class="rounded-[2rem] border border-[var(--line)] bg-white p-6 shadow-[0_20px_80px_rgba(29,29,31,0.05)] sm:p-8">
            <p class="text-sm font-semibold tracking-[0.04em] text-[var(--accent)]">
              0{index + 1}
            </p>
            <h3 class="mt-4 font-[family:var(--font-title)] text-[1.9rem] font-semibold leading-tight tracking-[-0.015em] text-[var(--ink)] sm:mt-5 sm:text-3xl">
              {capability.title}
            </h3>
            <p class="mt-4 leading-7 text-[var(--muted)] sm:leading-8">{capability.summary}</p>
          </section>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-10 sm:pb-28">
      <div class="rounded-[2rem] bg-[var(--ink)] px-5 py-10 text-center text-white shadow-[0_30px_120px_rgba(29,29,31,0.16)] sm:rounded-[2.5rem] sm:px-12 sm:py-20">
        <p class="text-sm font-semibold tracking-[0.04em] text-white/55">PRIVACY / VALUE</p>
        <h2 class="mt-4 font-[family:var(--font-title)] text-[clamp(2.1rem,11vw,4.8rem)] font-semibold leading-[1.02] tracking-[-0.02em]">
          Local by design.
        </h2>
        <p class="mx-auto mt-5 max-w-4xl text-[clamp(1rem,4.5vw,1.75rem)] leading-[1.65] tracking-[-0.025em] text-white/72 sm:mt-6 sm:leading-[1.6]">
          {project.privacy}
        </p>
      </div>
    </section>
  </article>
</BaseLayout>
