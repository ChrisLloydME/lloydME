---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props as Props;
---

<article class="group rounded-[2rem] border border-[var(--line)] bg-white p-7 shadow-[0_18px_60px_rgba(29,29,31,0.05)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_28px_90px_rgba(29,29,31,0.1)]">
  <a class="block" href={`/projects/${project.slug}/`}>
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <img
          src={project.icon}
          alt={`${project.name} app icon`}
          class="app-icon-shadow h-24 w-24 rounded-[24px] sm:h-28 sm:w-28 sm:rounded-[28px]"
        />

        <div class="max-w-3xl">
          <p class="text-sm font-semibold tracking-[-0.01em] text-[var(--accent)]">{project.category}</p>
          <h2 class="mt-3 font-[family:var(--font-title)] text-3xl font-semibold tracking-[-0.015em] text-[var(--ink)]">
            {project.name}
          </h2>
          <p class="mt-4 font-[family:var(--font-title)] text-xl font-semibold leading-8 tracking-[-0.01em] text-[var(--ink)]">
            {project.headline}
          </p>
          <p class="mt-4 leading-8 text-[var(--muted)]">{project.summary}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((item) => (
              <span class="rounded-full bg-[var(--surface-strong)] px-3 py-1 text-sm text-[var(--muted)]">
                {item}
              </span>
            ))}
          </div>
        </div>
    </div>
  </a>
</article>
