---
import type { Project } from "../data/projects";
import { withBase } from "../utils/paths";

interface Props {
  project: Project;
}

const { project } = Astro.props as Props;
---

<article class="project-card group rounded-[2rem] border border-[var(--line)] bg-[var(--surface)] p-5 shadow-[var(--card-shadow)] transition duration-200 hover:-translate-y-1 hover:shadow-[var(--card-shadow-hover)] sm:p-7">
  <a class="block" href={withBase(`/projects/${project.slug}/`)}>
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <img
          src={withBase(project.icon)}
          alt={`${project.name} app icon`}
          class="app-icon-shadow h-24 w-24 rounded-[24px] sm:h-28 sm:w-28 sm:rounded-[28px]"
        />

        <div class="max-w-3xl">
          <p class="text-sm font-semibold tracking-[-0.01em] text-[var(--accent)]">{project.category}</p>
          <h2 class="mt-3 font-[family:var(--font-title)] text-[1.85rem] font-semibold leading-tight tracking-[-0.015em] text-[var(--ink)] sm:text-3xl">
            {project.name}
          </h2>
          <p class="mt-4 font-[family:var(--font-title)] text-lg font-semibold leading-7 tracking-[-0.01em] text-[var(--ink)] sm:text-xl sm:leading-8">
            {project.headline}
          </p>
          <p class="mt-4 leading-7 text-[var(--muted)] sm:leading-8">{project.summary}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((item) => (
              <span class="rounded-full bg-[var(--surface-strong)] px-3 py-1 text-sm text-[var(--muted)]">
                {item}
              </span>
            ))}
          </div>
        </div>
    </div>
  </a>
</article>
