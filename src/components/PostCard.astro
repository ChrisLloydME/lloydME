---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../utils/paths";
import { formatDate, getPostSlug, tagToSlug } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
  variant?: "default" | "feature";
}

const { post, variant = "default" } = Astro.props as Props;
const postSlug = getPostSlug(post);
const postHref = withBase(`/blog/${postSlug}/`);
---

<article
  class:list={[
    "reveal card-surface overflow-hidden rounded-[1.6rem] border border-[var(--line)] bg-white shadow-[0_16px_48px_rgba(29,29,31,0.04)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_24px_70px_rgba(29,29,31,0.08)]",
    variant === "feature" && "border-[var(--line-strong)]",
  ]}
>
  <div class:list={["grid h-full min-h-0", post.data.heroImage && "md:grid-cols-[minmax(15rem,22rem)_minmax(0,1fr)]"]}>
    {
      post.data.heroImage && (
        <a class="block h-full overflow-hidden bg-[var(--surface-strong)]" href={postHref}>
          <img
            src={withBase(post.data.heroImage)}
            alt={post.data.heroImageAlt ?? post.data.title}
            class="h-52 w-full object-cover object-center transition duration-300 md:h-full md:min-h-[17rem] md:hover:scale-[1.02]"
          />
        </a>
      )
    }

    <div class="flex h-full flex-col justify-between px-5 py-5 sm:px-6 sm:py-6">
      <div class="space-y-4">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-[0.79rem] font-medium tracking-[0.01em] text-[var(--muted)]">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
          <span>{post.data.tags.length > 0 ? `${post.data.tags.length} tags` : "Essay"}</span>
        </div>

        <h3 class="max-w-3xl font-[family:var(--font-title)] text-2xl font-semibold leading-[1.08] tracking-[-0.02em] text-[var(--ink)] sm:text-[2rem]">
          <a class="transition hover:text-[var(--accent)]" href={postHref}>
            {post.data.title}
          </a>
        </h3>

        {
          post.data.description && (
            <p class="max-w-3xl text-[1rem] leading-7 text-[var(--muted)] line-clamp-3">
              {post.data.description}
            </p>
          )
        }
      </div>

      <div class="mt-6 flex flex-wrap items-end justify-between gap-4 border-t border-[var(--line)] pt-4">
        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <a
                  class="rounded-full bg-[var(--surface-strong)] px-3 py-1 text-sm text-[var(--muted)] transition hover:text-[var(--accent)]"
                  href={withBase(`/tags/${tagToSlug(tag)}/`)}
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }

        <a class="link-action shrink-0 text-sm" href={postHref}>
          Read article
          <span aria-hidden="true">&gt;</span>
        </a>
      </div>
    </div>
  </div>
</article>
