---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostSlug, tagToSlug } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
  variant?: "default" | "feature";
}

const { post, variant = "default" } = Astro.props as Props;
const postSlug = getPostSlug(post);
---

<article
  class:list={[
    "reveal card-surface overflow-hidden rounded-[1.6rem] border border-[var(--line)] bg-white px-0 py-0 shadow-[0_16px_48px_rgba(29,29,31,0.04)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_24px_70px_rgba(29,29,31,0.08)]",
    variant === "feature" && "border-[var(--line-strong)]",
  ]}
>
  {
    post.data.heroImage && (
      <a class="block" href={`/blog/${postSlug}/`}>
        <img
          src={post.data.heroImage}
          alt={post.data.heroImageAlt ?? post.data.title}
          class="h-56 w-full object-cover object-center"
        />
      </a>
    )
  }

  <div class="flex h-full flex-col justify-between px-6 py-7 sm:px-8 sm:py-8">
    <div class="space-y-5">
      <div class="flex flex-wrap items-center gap-3 text-[0.8rem] font-medium tracking-[0.01em] text-[var(--muted)]">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
        <span>{post.data.tags.length > 0 ? `${post.data.tags.length} tags` : "Essay"}</span>
      </div>

      <h3 class="font-[family:var(--font-title)] text-3xl font-semibold leading-tight tracking-[-0.015em] text-[var(--ink)]">
        <a class="transition hover:text-[var(--accent)]" href={`/blog/${postSlug}/`}>
          {post.data.title}
        </a>
      </h3>

      {
        post.data.description && (
          <p class="max-w-2xl text-lg leading-8 text-[var(--muted)]">{post.data.description}</p>
        )
      }
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-[var(--line)] pt-5">
      {
        post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <a
                class="rounded-full bg-[var(--surface-strong)] px-3 py-1 text-sm text-[var(--muted)] transition hover:text-[var(--accent)]"
                href={`/tags/${tagToSlug(tag)}/`}
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }

      <a class="link-action text-sm" href={`/blog/${postSlug}/`}>
        Read article
        <span aria-hidden="true">&gt;</span>
      </a>
    </div>
  </div>
</article>
