---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostSlug, tagToSlug } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
  variant?: "default" | "feature";
}

const { post, variant = "default" } = Astro.props as Props;
const postSlug = getPostSlug(post);
---

<article
  class:list={[
    "reveal card-surface flex h-full flex-col justify-between rounded-2xl p-6 transition duration-300 hover:-translate-y-1 hover:border-[rgba(196,111,71,0.35)] hover:shadow-[0_24px_50px_rgba(16,33,58,0.12)]",
    variant === "feature" && "bg-[var(--surface-strong)]",
  ]}
>
  <div class="space-y-4">
    <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
      <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
      <span>{post.data.tags.length > 0 ? `${post.data.tags.length} 个标签` : "随笔"}</span>
    </div>

    <h3 class="font-serif text-2xl leading-tight text-[var(--ink)]">
      <a class="transition hover:text-[var(--accent)]" href={`/blog/${postSlug}/`}>
        {post.data.title}
      </a>
    </h3>

    <p class="text-base leading-7 text-[var(--muted)]">{post.data.description}</p>
  </div>

  {
    post.data.tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <a
            class="rounded-md border border-[var(--line)] bg-white/70 px-3 py-1 text-sm text-[var(--muted)] transition hover:border-[var(--accent)] hover:text-[var(--accent)]"
            href={`/tags/${tagToSlug(tag)}/`}
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</article>
