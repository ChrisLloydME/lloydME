---
type Action = {
  href: string;
  label: string;
  tone?: "primary" | "secondary";
};

type Metric = {
  value: string;
  label: string;
};

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  actions?: Action[];
  metrics?: Metric[];
}

const {
  eyebrow,
  title,
  summary,
  actions = [],
  metrics = [],
} = Astro.props as Props;
---

<section class="reveal">
  <div class="px-7 py-14 text-center sm:px-12 sm:py-20">
    <p class="section-kicker">{eyebrow}</p>
    <h1 class="section-heading mx-auto mt-4 max-w-5xl">
      {title}
    </h1>
    <p class="section-copy mx-auto mt-6">{summary}</p>

    {
      actions.length > 0 && (
        <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3">
          {actions.map((action) => (
            <a
              class:list={[
                "link-action",
                action.tone === "secondary" && "text-[#2997ff]",
              ]}
              href={action.href}
            >
              {action.label}
              <span aria-hidden="true">&gt;</span>
            </a>
          ))}
        </div>
      )
    }

    {
      metrics.length > 0 && (
        <div
          class="mt-12 border-t border-[var(--line)] pt-8 text-center sm:grid sm:grid-cols-3 sm:divide-x sm:divide-[var(--line)]"
        >
          {metrics.map((metric) => (
            <div class="px-6 py-6">
              <p class="text-4xl font-semibold tracking-[-0.04em] text-[var(--ink)]">
                {metric.value}
              </p>
              <p class="mt-2 text-sm text-[var(--muted)]">{metric.label}</p>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
