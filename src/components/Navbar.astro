---
import { NAVIGATION, SITE_TITLE } from "../consts";
import { withBase } from "../utils/paths";

const normalizePath = (path: string) =>
  path === "/" ? "/" : path.replace(/\/+$/, "");

const pathname = normalizePath(Astro.url.pathname);
---

<header
  class="sticky top-0 z-40 border-b border-white/10 bg-[rgba(29,29,31,0.88)] backdrop-blur-xl"
>
  <div class="mx-auto max-w-[1120px] px-4 py-3 sm:px-6 sm:py-4">
    <nav class="flex flex-wrap items-center justify-between gap-x-4 gap-y-3">
      <a class="font-[family:var(--font-title)] text-lg font-semibold tracking-[-0.01em] text-white sm:text-xl" href={withBase("/")}>
        {SITE_TITLE}
      </a>

      <div class="flex w-full flex-wrap items-center gap-x-3 gap-y-1.5 sm:w-auto sm:justify-end">
        {
          NAVIGATION.map((item) => {
            const itemHref = withBase(item.href);
            const itemPath = normalizePath(itemHref);
            const isActive =
              pathname === itemPath ||
              (itemPath !== "/" && pathname.startsWith(`${itemPath}/`));

            return (
              <a
                class:list={[
                  "border-b border-transparent px-1 py-1.5 text-[13px] font-medium transition sm:px-2 sm:text-sm",
                  isActive
                    ? "border-white text-white"
                    : "text-white/72 hover:border-white/20 hover:text-white",
                ]}
                href={itemHref}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>
    </nav>
  </div>
</header>
