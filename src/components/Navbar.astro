---
import { NAVIGATION, SITE_TITLE } from "../consts";

const normalizePath = (path: string) =>
  path === "/" ? "/" : path.replace(/\/+$/, "");

const pathname = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-40 border-b border-[var(--line)] bg-white/88 backdrop-blur-xl">
  <div class="mx-auto max-w-[1120px] px-4 py-4 sm:px-6">
    <nav class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <a class="text-lg font-semibold tracking-[-0.03em] text-[var(--ink)] sm:text-xl" href="/">
        {SITE_TITLE}
      </a>

      <div class="flex flex-wrap items-center gap-1.5">
        {
          NAVIGATION.map((item) => {
            const itemPath = normalizePath(item.href);
            const isActive =
              pathname === itemPath ||
              (itemPath !== "/" && pathname.startsWith(`${itemPath}/`));

            return (
              <a
                class:list={[
                  "border-b border-transparent px-1 py-1.5 text-[13px] font-medium transition sm:px-2 sm:text-sm",
                  isActive
                    ? "border-[var(--ink)] text-[var(--ink)]"
                    : "text-[var(--muted)] hover:border-[var(--line)] hover:text-[var(--ink)]",
                ]}
                href={item.href}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>
    </nav>
  </div>
</header>
