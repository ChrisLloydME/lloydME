---
import { NAVIGATION, SITE_TITLE } from "../consts";

const normalizePath = (path: string) =>
  path === "/" ? "/" : path.replace(/\/+$/, "");

const pathname = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-40 px-4 py-4 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <nav class="card-surface flex flex-col gap-4 rounded-2xl px-5 py-4 md:flex-row md:items-center md:justify-between">
      <a class="font-serif text-2xl font-semibold tracking-[0.04em] text-[var(--ink)]" href="/">
        {SITE_TITLE}
      </a>

      <div class="flex flex-wrap items-center gap-2">
        {
          NAVIGATION.map((item) => {
            const itemPath = normalizePath(item.href);
            const isActive =
              pathname === itemPath ||
              (itemPath !== "/" && pathname.startsWith(`${itemPath}/`));

            return (
              <a
                class:list={[
                  "rounded-lg px-4 py-2 text-sm transition",
                  isActive
                    ? "bg-[var(--ink)] text-white"
                    : "text-[var(--muted)] hover:bg-[var(--accent-soft)] hover:text-[var(--ink)]",
                ]}
                href={item.href}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>
    </nav>
  </div>
</header>
