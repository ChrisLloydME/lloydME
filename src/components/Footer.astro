---
import { SITE_TITLE } from "../consts";

const currentYear = new Date().getFullYear();
---

<footer class="px-4 pb-10 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <div
      class="card-surface flex flex-col gap-4 rounded-2xl px-6 py-6 text-sm text-[var(--muted)] sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="font-serif text-lg text-[var(--ink)]">{SITE_TITLE}</p>
        <p>Built as a static Astro site, ready for GitHub + Cloudflare Pages deployment.</p>
      </div>
      <p>&copy; {currentYear} Lloyd. All rights reserved.</p>
    </div>
  </div>
</footer>
